            "url": "{{baseUrl}}/customers/{{customerId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Ahmet\",\n  \"lastName\": \"Yilmaz Updated\",\n  \"phoneNumber\": \"5557654321\",\n  \"email\": \"ahmet.updated@test.com\",\n  \"address\": \"Ankara\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "const response = pm.response.json();",
                  "pm.test('Last name is updated', function () { pm.expect(response.lastName).to.eql('Yilmaz Updated'); });",
                  "pm.test('Phone number is updated', function () { pm.expect(response.phoneNumber).to.eql('5557654321'); });",
                  "pm.test('Identity number is not changed', function () { pm.expect(response.identityNumber).to.eql('12345678901'); });"
                ]
              }
            }
          ]
