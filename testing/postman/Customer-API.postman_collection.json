  "item": [
    {
      "name": "Customer API Test Cases",
      "item": [
        {
          "name": "06 - Get Empty Customer List",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/customers"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "const response = pm.response.json();",
                  "pm.test('Response is an array', function () { pm.expect(response).to.be.an('array'); });",
                  "pm.test('Customer list is empty', function () { pm.expect(response.length).to.eql(0); });"
                ]
              }
            }
          ]
        },
        {
          "name": "01 - Create Customer - Success",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/customers",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identityNumber\": \"12345678901\",\n  \"firstName\": \"Ahmet\",\n  \"lastName\": \"Yilmaz\",\n  \"birthDate\": \"1995-05-10\",\n  \"phoneNumber\": \"5551234567\",\n  \"email\": \"ahmet@test.com\",\n  \"address\": \"Istanbul\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 201', function () { pm.response.to.have.status(201); });",
                  "pm.test('Response time is less than 1000 ms', function () { pm.expect(pm.response.responseTime).to.be.below(1000); });",
                  "const response = pm.response.json();",
                  "pm.environment.set('customerId', response.customerId);",
                  "pm.test('Customer ID is generated', function () { pm.expect(response.customerId).to.exist; });",
                  "pm.test('Default status is ACTIVE', function () { pm.expect(response.status).to.eql('ACTIVE'); });",
                  "pm.test('Created date exists', function () { pm.expect(response.createdDate).to.exist; });",
                  "pm.test('Updated date exists', function () { pm.expect(response.updatedDate).to.exist; });"
                ]
              }
            }
          ]
        },
        {
